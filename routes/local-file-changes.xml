<routes>
    <route id="local-file-changes">
        <from uri="scheduler:file-change-watcher?delay=5000&amp;initialDelay=0"/>
        <bean ref="fileChangeWatcher" method="watchDirectory(&quot;C:/Users/Lenovo/Documents&quot;)"/>
        <bean ref="fileChangeWatcher" method="watchDirectory(&quot;G:/My Drive&quot;)"/>
    </route>
    <route id="content-receive">
        <from uri="file:content-receive?delete=true"/>
        <to uri="bean:contentReceive"/>
    </route>
</routes>